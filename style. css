/* General Page Styling */
body {
    font-family: Arial, sans-serif;
    background-color: #f0f8ff;
    margin: 0;
    padding: 0;
}

/* Header */
header {
    background-color: #0066cc;
    color: white;
    text-align: center;
    padding: 20px;
}

header h1 {
    margin: 0;
}

/* Main Container */
.container {
    width: 500px;
    margin: 30px auto;
}

/* Form Card */
form {
    background: white;
    padding: 20px;
    border-radius: 10px;
    box-shadow: 0 0 10px rgba(0, 0, 0, 0.15);
}

/* Labels */
label {
    font-weight: bold;
    display: block;
    margin-top: 10px;
}

/* Inputs and Select */
input,
select {
    width: 100%;
    padding: 10px;
    margin-top: 5px;
    margin-bottom: 15px;
    border: 1px solid #ccc;
    border-radius: 5px;
    box-sizing: border-box;
}

/* Button */
button {
    width: 100%;
    background-color: #0066cc;
    color: white;
    border: none;
    padding: 12px;
    border-radius: 5px;
    cursor: pointer;
    font-size: 16px;
}

button:hover {
    background-color: #004c99;
}

/* Appointment List */
.appointments {
    margin-top: 20px;
    background: white;
    padding: 15px;
    border-radius: 10px;
    box-shadow: 0 0 10px rgba(0, 0, 0, 0.15);
}

.appointments h2 {
    margin-top: 0;
}

#appointmentList {
    list-style-type: none;
    padding: 0;
}

#appointmentList li {
    padding: 10px;
    border-bottom: 1px solid #ddd;
}

#appointmentList li:last-child {
    border-bottom: none;
}

/* Responsive Design */
@media (max-width: 600px) {
    .container {
        width: 90%;
    }
}
