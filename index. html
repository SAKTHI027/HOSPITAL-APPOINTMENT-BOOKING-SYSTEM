<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Hospital Appointment Booking System</title>

<link rel="stylesheet" href="style.css">

</head>
<body>

<header>
    <h1>Hospital Appointment Booking System</h1>
</header>

<div class="container">
    <div class="card">
        <h2>Book an Appointment</h2>

        <input type="text" id="patientName" placeholder="Enter Patient Name">

        <input type="number" id="patientAge" placeholder="Enter Age">

        <select id="doctor">
            <option value="">Select Doctor</option>
            <option>Dr. Smith - Cardiologist</option>
            <option>Dr. John - Neurologist</option>
            <option>Dr. Priya - Pediatrician</option>
            <option>Dr. Kumar - General Physician</option>
        </select>

        <input type="date" id="appointmentDate">

        <button onclick="bookAppointment()">Book Appointment</button>

        <div id="result"></div>
    </div>
</div>

<script src="script.js"></script>

</body>
</html>
